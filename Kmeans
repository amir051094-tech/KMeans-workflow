x=data
# Elbow curve 
from sklearn.cluster import KMeans
sse={}
for k in range(1,6):
    kmeans=KMeans(n_clusters=k,max_iter=1000).fit(x)
    sse[k]=kmeans.inertia_
    print (round(kmeans.inertia_,2))# gives distance

#visualize the curve 

plt.plot(list(sse.keys()), list(sse.values()))
plt.title("Elbow curve")
plt.xlabel("k cluster")
plt.ylabel("Inertia")
plt.show()

#Silhoutee score 

from sklearn.metrics import silhouette_score

silhouette_scores=[]
for n_cluster in range(2,5):
    silhouette_scores.append(silhouette_score(x,KMeans(n_clusters=n_cluster).fit_predict(x)))

k=[2,3,4]
plt.bar(k,silhouette_scores,color='blue')
plt.title("silhouette score")
plt.xlabel("k value")
plt.ylabel("silhouette score")
plt.show()
print(silhouette_scores)

best_score=max(silhouette_scores)
best_k=k[silhouette_scores.index(best_score)]

best_k,best_score

#standardize ,normalize and extract before fitting in kmeans model 

from sklearn.preprocessing import StandardScaler,normalize

scaler=StandardScaler()
x_scaled=scaler.fit_transform(x)

x_normal=normalize(x_scaled)
x_normal=pd.DataFrame(x_normal)

from sklearn.decomposition import PCA #feature extraction

pc=PCA(n_components=2)

x_pc=pc.fit_transform(x_normal)
x_pc=pd.DataFrame(x_pc)
x_pc.columns=['pc1','pc2']
x_pc.head(2)


#Find the grouping and visualize 

kmeans=KMeans(n_clusters=2)

plt.scatter(x_pc.iloc[:,0],x_pc.iloc[:,1],c=kmeans.fit_predict(x_pc),cmap=plt.cm.rainbow)
plt.grid(True)
plt.show()

